generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// NextAuth.js v5 required tables
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// Application tables
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("student") @db.VarChar(10)
  createdAt     DateTime  @default(now())

  accounts        Account[]
  sessions        Session[]
  learningRecords LearningRecord[]
  answerHistory   AnswerHistory[]
  mockTests       MockTest[]
  lecturePhotos   LecturePhoto[]

  @@map("users")
}

model Question {
  id               Int      @id @default(autoincrement())
  questionType     String   @default("four_choice") @db.VarChar(20)
  categoryCode     String   @db.VarChar(10)
  categoryName     String   @db.VarChar(100)
  questionText     String   @db.Text
  choiceA          String   @db.Text
  choiceB          String   @db.Text
  choiceC          String   @default("") @db.Text
  choiceD          String   @default("") @db.Text
  correctAnswers   String   @db.VarChar(10)
  correctFeedback  String?  @db.Text
  incorrectFeedback String? @db.Text
  similarityGroup  Int?

  learningRecords LearningRecord[]
  answerHistory   AnswerHistory[]

  @@index([questionType], map: "idx_questions_type")
  @@index([categoryCode], map: "idx_questions_category")
  @@index([similarityGroup], map: "idx_questions_similarity")
  @@map("questions")
}

model LearningRecord {
  id              Int       @id @default(autoincrement())
  userId          String
  questionId      Int
  easinessFactor  Decimal   @default(2.50) @db.Decimal(4, 2)
  intervalDays    Int       @default(0)
  repetitions     Int       @default(0)
  nextReviewDate  DateTime? @db.Date
  status          String    @default("new") @db.VarChar(20)
  totalAttempts   Int       @default(0)
  correctCount    Int       @default(0)
  lastAnswer      String?   @db.VarChar(4)
  lastQuality     Int?
  lastAttemptedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextReviewDate], map: "idx_lr_user_review")
  @@index([userId, status], map: "idx_lr_user_status")
  @@map("learning_records")
}

model AnswerHistory {
  id             Int      @id @default(autoincrement())
  userId         String
  questionId     Int
  selectedAnswer String   @db.VarChar(4)
  isCorrect      Boolean
  quality        Int
  responseTimeMs Int?
  sessionType    String   @default("daily") @db.VarChar(20)
  answeredAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, answeredAt(sort: Desc)], map: "idx_ah_user_time")
  @@index([sessionType, answeredAt], map: "idx_ah_session")
  @@map("answer_history")
}

model MockTest {
  id          Int       @id @default(autoincrement())
  userId      String
  score       Int
  total       Int       @default(25)
  passed      Boolean
  startedAt   DateTime
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mock_tests")
}

model LecturePhoto {
  id        String   @id @default(cuid())
  userId    String
  unitId    String   @db.VarChar(3)
  slotId    String   @db.VarChar(50)
  s3Key     String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, unitId, slotId])
  @@index([userId, unitId], map: "idx_lp_user_unit")
  @@map("lecture_photos")
}
